# ===== mcp-cirujanos — variables de entorno =====
# Servidor
PORT=3000
NODE_ENV=production
TIMEZONE=America/Bogota

# Seguridad del endpoint /mcp (header x-api-key o Authorization: Bearer)
API_KEY=cambia-esta-clave

# Rendimiento
CACHE_TTL_SECONDS=120
RATE_LIMIT_PER_MINUTE=60

# Duración/!buffer de la consulta (valoración = 45 min)
DEFAULT_SLOT_MINUTES=45
DEFAULT_BUFFER_MINUTES=0

# ===== Archivos de configuración (rutas; multi-tenant) =====
# BARBERS_JSON: cada "barbero" = un médico con su calendarId de Google.
BARBERS_JSON=./data/doctors.json
BUSINESS_HOURS_JSON=./data/business_hours.json
# CATALOG_JSON: parche mcp-cirujanos — servicios/valoración del consultorio (antes hardcodeado).
CATALOG_JSON=./data/catalog.json
# CASOS_JSON: biblioteca antes/después (tool buscar_casos, M1 del guion).
CASOS_JSON=./data/casos.json

# ===== Google Calendar (Service Account) =====
# Reutiliza la MISMA SA de mcp-valeria (mcp-valeria@zobra-pruebas.iam.gserviceaccount.com).
# Pega el JSON completo de la service account (una sola línea). EN EASYPANEL: copiar el env
# GOOGLE_APPLICATION_CREDENTIALS_JSON desde el servicio mcp-valeria (la SA nunca sale de EasyPanel).
# El calendarId de cada médico debe estar COMPARTIDO con permiso de escritura al client_email de la SA.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Alternativas (opcionales): ruta a archivo o base64
# GOOGLE_SA_KEYFILE=/run/secrets/sa.json
# GOOGLE_SA_JSON_BASE64=
